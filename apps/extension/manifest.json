{
  "name": "JobGenius Saver",
  "version": "0.1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "storage", "scripting", "alarms", "tabs"],
  "host_permissions": [
    "https://*.vercel.app/*",
    "http://localhost:3000/*",
    "https://*.linkedin.com/*",
    "https://*.greenhouse.io/*",
    "https://*.workday.com/*",
    "https://*.myworkdayjobs.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
