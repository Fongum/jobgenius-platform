NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email provider
EMAIL_FROM_ADDRESS=
EMAIL_SEND_PROVIDER=stub
RESEND_API_KEY=
OUTREACH_FROM_EMAIL=
OUTREACH_REPLY_TO_EMAIL=

# Outreach automation
OUTREACH_WEBHOOK_SECRET=
OUTREACH_TRACK_BASE_URL=
OUTREACH_NO_REPLY_HOURS=72
OUTREACH_OPENED_NO_REPLY_HOURS=36
OUTREACH_MAX_FOLLOWUPS=2

# Voice automation telephony (Retell AI)
RETELL_API_KEY=
RETELL_BASE_URL=https://api.retellai.com
# Optional dedicated webhook signing secret. Falls back to RETELL_API_KEY if unset.
RETELL_WEBHOOK_SECRET=
RETELL_DEFAULT_FROM_NUMBER=
RETELL_OUTBOUND_ENABLED=false

# Comma-separated overrides (optional):
# OUTREACH_REQUIRED_CONSENTS=OUTREACH_AUTOMATION,OUTREACH_CONTACT_AUTHORIZATION,OUTREACH_DATA_USAGE

# OpenAI (optional - enables AI-powered resume parsing)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Stronger model for resume tailoring (Mode 3 "Tailor resume & autofill" + AM
# resume-tailor). Optional; falls back to OPENAI_MODEL when unset.
RESUME_TAILOR_MODEL=
OPENAI_REALTIME_MODEL=gpt-realtime-mini
OPENAI_REALTIME_VOICE=alloy

# Ops
OPS_API_KEY=

# Runner auth
RUNNER_AUTH_TOKEN=
RUNNER_AM_EMAIL=

# Intelligence / feedback loop
INTELLIGENCE_WINDOW_DAYS=60
AUTO_THRESHOLD_ENABLED=false
AUTO_THRESHOLD_MIN_RUNS=12
AUTO_THRESHOLD_MIN_BAND_RUNS=4
AUTO_THRESHOLD_TARGET_SUCCESS=0.35
AUTO_THRESHOLD_MAX_STEP=10
AUTO_THRESHOLD_MIN=50
AUTO_THRESHOLD_MAX=85
AUTO_THRESHOLD_COOLDOWN_DAYS=14

# Mode 3 host graduation (optional; OFF by default). When enabled, a host that
# interactive autofill has learned well (enough high-trust learned_field_rules
# and a low correction rate) is allowed to auto-apply unattended even without a
# curated host rule. Leave unset until Mode 3 learning has accumulated in prod.
MODE3_HOST_GRADUATION=0
MODE3_GRADUATION_MIN_RULES=3
MODE3_GRADUATION_MIN_EVENTS=8
MODE3_GRADUATION_MAX_CORRECTION_RATE=0.25
